rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // user docs (existing)
    match /artifacts/{appId}/users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // expense items: existing rule (broad for simplicity)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Telegram Mini App binding codes (one-time, short-lived, owned by user)
    match /tgBindCodes/{code} {
      // Anyone signed in can create their own pending code.
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == 'pending';
      // Owner can read the status of their code.
      allow read: if request.auth != null
        && (resource == null || resource.data.uid == request.auth.uid);
      // Updates only via Cloud Function (admin SDK bypasses rules)
      allow update, delete: if false;
    }

    // Telegram ↔ Expense binding records: server-managed only
    match /tgAccounts/{tgId} {
      allow read: if request.auth != null
        && (resource == null || resource.data.uid == request.auth.uid);
      allow write: if false;
    }
  }
}
